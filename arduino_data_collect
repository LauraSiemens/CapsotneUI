/***************************************************************************
 BME680 + BMV080 + ESP32 Bluetooth Serial
***************************************************************************/

#include <Wire.h>
#include <SPI.h>
#include <Adafruit_Sensor.h>
#include "Adafruit_BME680.h"
#include "SparkFun_BMV080_Arduino_Library.h"
#include "BluetoothSerial.h"

#define SEALEVELPRESSURE_HPA (1013.25)

// I2C addresses
#define BME680_ADDR 0x77
#define BMV080_ADDR 0x57

Adafruit_BME680 bme;       // BME680 over I2C
SparkFunBMV080 bmv080;     // BMV080 over I2C

#ifdef ARDUINO_SPARKFUN_THINGPLUS_RP2040
#define wirePort Wire1
#else
#define wirePort Wire
#endif

#if !defined(CONFIG_BT_ENABLED) || !defined(CONFIG_BLUEDROID_ENABLED)
#error Bluetooth is not enabled! Enable it in menuconfig
#endif

BluetoothSerial SerialBT;

void setup() {
 Serial.begin(115200);
 delay(1000);
 Serial.println("Booting...");

 // Bluetooth
 SerialBT.begin("ESP32");
 Serial.println("Bluetooth started: ESP32");

 // I2C
 wirePort.begin();

 // ---- BMV080 ----
 if (!bmv080.begin(BMV080_ADDR, wirePort)) {
   Serial.println("BMV080 not found");
   SerialBT.println("BMV080 not found");
 } else {
   bmv080.init();
   bmv080.setMode(SF_BMV080_MODE_CONTINUOUS);
   Serial.println("BMV080 OK");
 }

 // ---- BME680 ----
 if (!bme.begin(BME680_ADDR)) {
   Serial.println("BME680 not found");
   SerialBT.println("BME680 not found");
   while(1);
 } else {
   bme.setTemperatureOversampling(BME680_OS_8X);
   bme.setHumidityOversampling(BME680_OS_2X);
   bme.setPressureOversampling(BME680_OS_4X);
   bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
   bme.setGasHeater(320, 150);
   Serial.println("BME680 OK");
 }

 Serial.println("Setup complete");
 SerialBT.println("PM1, PM2.5, PM10, Temp, Humidity, Gas, Pressure");
}

void loop() {
  // ---- BME680 reading ----
  float temperature = NAN;
  float humidity = NAN;
  float pressure = NAN;
  float gas = NAN;

  if (bme.beginReading()) {
    if (bme.endReading()) {
      temperature = bme.temperature;
      humidity = bme.humidity;
      pressure = bme.pressure / 100.0; // hPa
      gas = bme.gas_resistance;
    }
  }

  // ---- BMV080 reading ----
  float pm1 = NAN;
  float pm25 = NAN;
  float pm10 = NAN;

  if (bmv080.readSensor()) {
    pm1  = bmv080.PM1();
    pm25 = bmv080.PM25();
    pm10 = bmv080.PM10();
    Serial.println("BMV080 read successful");
  } else {
    Serial.println("BMV080 read failed");
  }

  // ---- Timestamp (ms since boot) ----
  unsigned long timestamp = millis();

  // ---- Create CSV line ----
  String dataLine = String(timestamp) + "," +
                    String(pm1) + "," +
                    String(pm25) + "," +
                    String(pm10) + "," +
                    String(temperature) + "," +
                    String(humidity) + "," +
                    String(gas) + "," +
                    String(pressure);

  // ---- Print to Serial Monitor ----
  Serial.println(dataLine);

  // ---- Print to Bluetooth ----
  SerialBT.println(dataLine);

  // ---- Read incoming BT data ----
  while (SerialBT.available()) {
    Serial.write(SerialBT.read());
  }

  delay(1000);
}
